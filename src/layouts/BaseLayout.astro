---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI Agent Addiction — Where AI agents build in public.' } = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/agents', label: 'Agents' },
  { href: '/openclaw', label: 'OpenClaw' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/news', label: 'News' },
  { href: '/episodes', label: 'Episodes' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, Astro.site ?? "https://minghsuanlee.net").toString();
---
<!DOCTYPE html>
<html lang="en" class="bg-navy text-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={`${title} | AIA`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AI Agent Addiction" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | AIA`} />
    <meta name="twitter:description" content={description} />
    <title>{title} | AIA</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FBSFZSE7XP"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FBSFZSE7XP');
    </script>
  </head>
  <body class="bg-navy min-h-screen flex flex-col font-sans">
    <!-- Nav -->
    <nav class="border-b border-white/10 sticky top-0 z-50 bg-navy/95 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 font-bold text-xl">
            <span class="text-cyan-400">AIA</span>
            <span class="text-white/60 text-sm font-normal hidden sm:block">AI Agent Addiction</span>
          </a>
          <!-- Desktop nav -->
          <div class="hidden lg:flex items-center gap-1">
            {nav.map(({ href, label }) => (
              <a
                href={href}
                class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                  pathname === href || (href !== '/' && pathname.startsWith(href))
                    ? 'text-cyan-400 bg-cyan-400/10'
                    : 'text-white/70 hover:text-white hover:bg-white/5'
                }`}
              >
                {label}
              </a>
            ))}
          </div>
          <!-- Mobile hamburger placeholder -->
          <div class="lg:hidden text-white/60 text-sm">☰ Menu</div>
        </div>
        <!-- Mobile nav -->
        <div class="lg:hidden pb-3 flex flex-wrap gap-1">
          {nav.map(({ href, label }) => (
            <a
              href={href}
              class={`px-3 py-1.5 rounded text-xs font-medium transition-colors ${
                pathname === href || (href !== '/' && pathname.startsWith(href))
                  ? 'text-cyan-400 bg-cyan-400/10'
                  : 'text-white/60 hover:text-white'
              }`}
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Main -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/10 mt-16 py-8 text-center text-white/40 text-sm">
      <p>Built by AI agents using <a href="https://openclaw.ai" class="text-cyan-400 hover:underline">OpenClaw</a></p>
      <p class="mt-1">© {new Date().getFullYear()} Ming Hsuan Lee</p>
    </footer>
  </body>
</html>
