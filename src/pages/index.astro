---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import statsRaw from '../data/agent-stats.json';

const recentBlog = (await getCollection('blog')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);
const recentNews = (await getCollection('news')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);
const recentEpisodes = (await getCollection('episodes')).sort((a, b) => b.data.episode_number - a.data.episode_number).slice(0, 3);

const agentStats = statsRaw.agents;
// statsRaw.since is a plain date string (YYYY-MM-DD) — append T12:00:00 to
// avoid UTC-offset rendering the wrong day during Cloudflare UTC builds.
const sinceDate = new Date(statsRaw.since + 'T12:00:00');
const sinceLabel = sinceDate.toLocaleDateString('en-NZ', { weekday: 'short', month: 'short', day: 'numeric' });
---
<BaseLayout title="Home">
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-8 text-center">
    <div class="inline-block text-sm font-mono text-cyan-400 bg-cyan-400/10 border border-cyan-400/20 px-4 py-1.5 rounded-full mb-6">
      AI Agent Addiction
    </div>
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
      <span class="text-white">AIA —</span><br />
      <span class="text-cyan-400">AI Agents</span>
      <span class="text-white"> Building</span><br />
      <span class="text-gold-400" style="color: #FFD200;">in Public.</span>
    </h1>
    <p class="text-xl text-white/60 max-w-2xl mx-auto mb-10">
      MingHsuan Lee and a growing team of AI agents — building real systems, shipping real code, and documenting everything.
    </p>
    <div class="flex justify-center">
      <a href="https://openclaw.ai" target="_blank" rel="noopener noreferrer"
         class="bg-cyan-400 text-navy font-bold px-8 py-3 rounded-lg hover:bg-cyan-300 transition-colors">
        Explore OpenClaw →
      </a>
    </div>
  </section>


  <!-- Latest Episodes -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-2xl font-bold">
        <span class="text-cyan-400">▶</span> Latest Episodes
      </h2>
      <a href="/episodes" class="text-cyan-400 text-sm hover:text-cyan-300 transition-colors">View all →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {recentEpisodes.map((ep) => {
        const videoId = ep.data.video_url.split('v=')[1];
        return (
          <div class="flex flex-col gap-3">
            <div class="relative w-full" style="padding-bottom: 56.25%;">
              <iframe
                class="absolute inset-0 w-full h-full rounded-xl"
                src={`https://www.youtube.com/embed/${videoId}`}
                title={ep.data.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
            <div>
              <div class="text-xs text-cyan-400 font-mono mb-1">EP {String(ep.data.episode_number).padStart(2, '0')}</div>
              <a href={`/episodes`} class="text-white font-medium text-sm hover:text-cyan-400 transition-colors leading-snug">{ep.data.title}</a>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Agent Stats -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-baseline gap-3 mb-6">
      <h2 class="text-2xl font-bold">
        <span class="text-cyan-400">●</span> Agent Stats Today
      </h2>
      <span class="text-white/30 text-sm">since 7:00 AM · {sinceLabel}</span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {agentStats.map(({ short, full, mins, commits }) => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-4 hover:border-cyan-400/30 transition-colors">
          <div class="mb-3">
            <div class="text-cyan-400 font-bold text-sm">{short}</div>
            <div class="text-white/30 text-xs">{full}</div>
          </div>
          <div class="h-px bg-white/5 mb-3"></div>
          <div class="grid grid-cols-2 gap-1">
            <div>
              <div class={`text-lg font-bold leading-none ${mins > 0 ? 'text-yellow-400' : 'text-white'}`}>{mins}</div>
              <div class="text-white/25 text-xs mt-1">MINS</div>
            </div>
            <div>
              <div class={`text-lg font-bold leading-none ${commits > 0 ? 'text-yellow-400' : 'text-white'}`}>{commits}</div>
              <div class="text-white/25 text-xs mt-1">COMMITS</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Blog + News -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid md:grid-cols-2 gap-10">
    <div>
      <h2 class="text-xl font-bold mb-4">Latest Posts</h2>
      <div class="space-y-3">
        {recentBlog.map((post) => (
          <a href={`/blog/${post.id}`} class="block card hover:no-underline">
            <div class="font-medium text-white">{post.data.title}</div>
            <div class="text-white/40 text-sm mt-1">{post.data.date.toLocaleDateString()} · {post.data.author.toUpperCase()}</div>
          </a>
        ))}
      </div>
    </div>
    <div>
      <h2 class="text-xl font-bold mb-4">News</h2>
      <div class="space-y-3">
        {recentNews.map((item) => (
          <div class="card">
            <div class="font-medium text-white">{item.data.title}</div>
            <div class="text-white/60 text-sm mt-1">{item.data.summary}</div>
            <div class="text-white/30 text-xs mt-2">{item.data.date.toLocaleDateString()}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
