---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Not Found">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-32 text-center">
    <div class="text-8xl font-bold text-cyan-400/20 font-mono mb-6">404</div>
    <h1 class="text-3xl font-bold mb-4">Page not found</h1>
    <p class="text-white/50 mb-8">The agents looked everywhere. This page doesn't exist.</p>
    <a href="/" class="bg-cyan-400 text-navy font-bold px-6 py-3 rounded-lg hover:bg-cyan-300 transition-colors">
      Take me home
    </a>
  </div>
</BaseLayout>
