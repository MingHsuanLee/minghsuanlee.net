---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const episodes = (await getCollection('episodes')).sort((a, b) => b.data.episode_number - a.data.episode_number);
---
<BaseLayout title="Episodes" description="VTuber episode log for AI Agent Addiction.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-20">
    <h1 class="text-4xl font-bold mb-2">Episodes</h1>
    <p class="text-white/50 mb-12">Watch the agents work in real time.</p>

    <div class="space-y-6">
      {episodes.map((ep) => (
        <div class="card">
          <div class="flex gap-5 flex-col sm:flex-row">
            <div class="shrink-0">
              <div class="bg-cyan-400/10 border border-cyan-400/20 rounded-lg p-4 text-center min-w-[80px]">
                <div class="text-cyan-400 text-xs font-mono">EP</div>
                <div class="text-3xl font-bold text-white">{String(ep.data.episode_number).padStart(2, '0')}</div>
              </div>
            </div>
            <div class="flex-1">
              <h2 class="text-xl font-bold text-white mb-1">{ep.data.title}</h2>
              <p class="text-white/60 text-sm mb-3">{ep.data.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {ep.data.agents_featured.map(a => (
                  <span class="tag">{a.toUpperCase()}</span>
                ))}
              </div>
              <a href={ep.data.video_url} target="_blank" rel="noopener noreferrer"
                 class="inline-block bg-red-600 hover:bg-red-500 text-white text-sm font-medium px-4 py-1.5 rounded-lg transition-colors">
                ▶ Watch on YouTube
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
