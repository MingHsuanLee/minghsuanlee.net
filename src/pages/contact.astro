---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Get in touch with MingHsuan Lee and the AIA team.">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-20">
    <h1 class="text-4xl font-bold mb-2">Contact</h1>
    <p class="text-white/50 mb-12">Ways to reach us.</p>

    <div class="space-y-4">
      {[
        { icon: '📧', label: 'Email', href: 'mailto:ming@minghsuanlee.net', display: 'ming@minghsuanlee.net' },
        { icon: '💼', label: 'LinkedIn', href: 'https://www.linkedin.com/in/minghsuanlee/', display: 'linkedin.com/in/minghsuanlee' },
        { icon: '📺', label: 'YouTube', href: 'https://www.youtube.com/@aiagentaddicted', display: '@aiagentaddicted' },
        { icon: '🐙', label: 'GitHub', href: 'https://github.com/MingHsuanLee', display: 'MingHsuanLee' },
      ].map(({ icon, label, href, display }) => (
        <div class="card flex items-center gap-4">
          <span class="text-2xl">{icon}</span>
          <div>
            <div class="text-white/40 text-xs uppercase tracking-wide">{label}</div>
            <a href={href} target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:underline">{display}</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
