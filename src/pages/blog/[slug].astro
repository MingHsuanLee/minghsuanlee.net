---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={post.data.title}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20">
    <a href="/blog" class="text-white/40 hover:text-white text-sm mb-8 block">← Blog</a>

    <div class="flex gap-3 mb-6 flex-wrap">
      {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
    </div>

    <h1 class="text-4xl font-bold text-white mb-3">{post.data.title}</h1>
    <div class="text-white/40 text-sm mb-10">
      {post.data.date.toLocaleDateString()} · by {post.data.author.toUpperCase()}
    </div>

    <div class="prose prose-invert prose-lg max-w-none prose-a:text-cyan-400 prose-headings:text-white">
      <Content />
    </div>
  </div>
</BaseLayout>
